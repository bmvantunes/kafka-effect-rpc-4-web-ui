{
  "name": "web-ui",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck:storybook": "tsc -p tsconfig.storybook.json --noEmit",
    "storybook": "node ./scripts/storybook-dev.mjs",
    "storybook:ui": "storybook dev -p 6006",
    "storybook:controller": "node --import tsx ./scripts/storybook-controller.ts",
    "build-storybook": "storybook build",
    "test:storybook": "vitest run --project=storybook",
    "test:storybook:watch": "vitest --project=storybook"
  },
  "dependencies": {
    "@effect/platform-browser": "4.0.0-beta.27",
    "effect": "4.0.0-beta.27",
    "next": "16.1.6",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.2.16",
    "@storybook/addon-docs": "^10.2.16",
    "@storybook/addon-vitest": "^10.2.16",
    "@storybook/nextjs-vite": "^10.2.16",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/browser": "^4.0.18",
    "@vitest/browser-playwright": "^4.0.18",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "playwright": "^1.58.2",
    "storybook": "^10.2.16",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "@effect/platform-browser": "4.0.0-beta.27",
    "effect": "4.0.0-beta.27"
  }
}
