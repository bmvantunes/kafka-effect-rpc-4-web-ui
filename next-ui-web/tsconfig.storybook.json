{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "types": ["node"]
  },
  "include": [
    "../shared/**/*.ts",
    "../backend/**/*.ts",
    ".storybook/**/*.ts",
    ".storybook/**/*.tsx",
    "stories/**/*.ts",
    "stories/**/*.tsx",
    "scripts/storybook-controller.ts",
    "lib/**/*.ts",
    "lib/**/*.tsx",
    "components/**/*.ts",
    "components/**/*.tsx"
  ],
  "exclude": ["node_modules", ".next"]
}
